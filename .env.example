OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_ANSWER_MODEL=gpt-4.1-mini
OPENAI_VERIFIER_MODEL=gpt-4.1-mini
CHROMA_PATH=./storage/chroma
NEO4J_URI=bolt://127.0.0.1:17687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
REDIS_URL=redis://localhost:6379/0
WORKSPACE_PATH=./storage/workspace
MAX_CONTEXT_TOKENS=8000
GRAPH_HOPS=2
QUERY_MAX_SECONDS=55
OPENAI_TIMEOUT_SECONDS=20
UI_REQUEST_TIMEOUT_SECONDS=90
INVENTORY_PAGE_SIZE=80
INVENTORY_MAX_PAGE_SIZE=300
INVENTORY_ALIAS_LIMIT=8
INVENTORY_ENTITY_LIMIT=500
SCAN_MAX_FILE_SIZE_BYTES=200000
SCAN_EXCLUDED_DIRS=.git,node_modules,dist,build,venv,.venv,__pycache__,.idea,.vscode,target,out,bin,obj,.gradle,.m2,.pytest_cache,.mypy_cache
SCAN_EXCLUDED_EXTENSIONS=.png,.jpg,.jpeg,.gif,.webp,.ico,.mp3,.mp4,.wav,.ogg,.pdf,.zip,.tar,.gz,.7z,.rar,.jar,.war,.ear,.class,.dll,.exe,.so,.dylib,.o,.a,.bin,.sqlite,.db
SCAN_EXCLUDED_FILES=.gitignore,.env
HEALTH_CHECK_STRICT=true
HEALTH_CHECK_TIMEOUT_SECONDS=5
HEALTH_CHECK_TTL_SECONDS=10
HEALTH_CHECK_OPENAI=true
HEALTH_CHECK_REDIS=false

API_IMAGE=kdb-rag-api:local
PYTHONPATH=/app/src
OPENAI_API_KEY=
LLM_PROVIDER=vertex
LLM_ANSWER_MODEL=gemini-2.5-flash
LLM_VERIFIER_MODEL=gemini-2.5-flash
LLM_VERIFY_ENABLED=false
EMBEDDING_PROVIDER=vertex
EMBEDDING_MODEL=text-embedding-005
GEMINI_API_KEY=
VERTEX_AI_AUTH_MODE=service_account
VERTEX_SERVICE_ACCOUNT_JSON_B64=
VERTEX_API_BASE_URL=https://us-central1-aiplatform.googleapis.com
VERTEX_API_VERSION=v1
VERTEX_GENERATE_CONTENT_PATH_TEMPLATE=/projects/{project}/locations/{location}/publishers/google/models/{model}:generateContent
VERTEX_PREDICT_PATH_TEMPLATE=/projects/{project}/locations/{location}/publishers/google/models/{model}:predict
VERTEX_MODELS_PATH_TEMPLATE=/projects/{project}/locations/{location}/publishers/google/models
VERTEX_AUTH_TOKEN_URL=https://oauth2.googleapis.com/token
# Legacy fallback opcional:
# VERTEX_AI_PROJECT_ID=
# VERTEX_AI_LOCATION=us-central1
VERTEX_AI_LABELS_ENABLED=true
VERTEX_AI_LABEL_SERVICE=webspec-coipo
VERTEX_AI_LABEL_SERVICE_ACCOUNT=qa-anthos
VERTEX_AI_LABEL_USE_CASE_ID=tbd
VERTEX_AI_CORRELATION_ID_ENABLED=true
CHROMA_PATH=/app/storage/chroma
CHROMA_MODE=remote
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_TOKEN=
CHROMA_HNSW_SPACE=cosine
POSTGRES_URL=postgresql://coderag:coderag@localhost:5432/coderag
POSTGRES_DB=coderag
POSTGRES_USER=coderag
POSTGRES_PASSWORD=coderag
POSTGRES_POOL_SIZE=5
POSTGRES_POOL_TIMEOUT=30
LEXICAL_FTS_LANGUAGE=english
NEO4J_URI=bolt://127.0.0.1:17687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
REDIS_URL=redis://localhost:6379/0
INGESTION_EXECUTION_MODE=thread
INGESTION_QUEUE_NAME=ingestion
INGESTION_JOB_TIMEOUT_SECONDS=7200
INGESTION_RESULT_TTL_SECONDS=86400
INGESTION_FAILURE_TTL_SECONDS=604800
INGESTION_RETRY_MAX=3
INGESTION_RETRY_INTERVALS=30,120,300
INGESTION_RETRY_TRANSIENT_ONLY=true
INGESTION_ENQUEUE_LOCK_SECONDS=30
INGESTION_ENQUEUE_LOCK_WAIT_SECONDS=5
GIT_SSH_KEY_CONTENT=
GIT_SSH_KEY_CONTENT_B64=
GIT_SSH_KNOWN_HOSTS_CONTENT=
GIT_SSH_KNOWN_HOSTS_CONTENT_B64=
GIT_SSH_STRICT_HOST_KEY_CHECKING=yes
WORKSPACE_PATH=./storage/workspace
MAX_CONTEXT_TOKENS=8000
GRAPH_HOPS=2
QUERY_MAX_SECONDS=55
OPENAI_TIMEOUT_SECONDS=60
UI_REQUEST_TIMEOUT_SECONDS=90
INVENTORY_PAGE_SIZE=80
INVENTORY_MAX_PAGE_SIZE=300
INVENTORY_ALIAS_LIMIT=8
INVENTORY_ENTITY_LIMIT=500
SCAN_MAX_FILE_SIZE_BYTES=200000
SCAN_EXCLUDED_DIRS=.git,node_modules,dist,build,venv,.venv,__pycache__,.idea,.vscode,target,out,bin,obj,.gradle,.m2,.pytest_cache,.mypy_cache
SCAN_EXCLUDED_EXTENSIONS=.png,.jpg,.jpeg,.gif,.webp,.ico,.mp3,.mp4,.wav,.ogg,.pdf,.zip,.tar,.gz,.7z,.rar,.jar,.war,.ear,.class,.dll,.exe,.so,.dylib,.o,.a,.bin,.sqlite,.db
SCAN_EXCLUDED_FILES=.gitignore,.env
SYMBOL_EXTRACTOR_V2_ENABLED=true
SEMANTIC_GRAPH_ENABLED=true
SEMANTIC_GRAPH_JAVA_ENABLED=true
SEMANTIC_GRAPH_JAVASCRIPT_ENABLED=true
SEMANTIC_GRAPH_TYPESCRIPT_ENABLED=true
SEMANTIC_GRAPH_QUERY_ENABLED=true
SEMANTIC_RELATION_TYPES=CALLS,IMPORTS,EXTENDS,IMPLEMENTS
SEMANTIC_RELATION_WEIGHTS=CALLS:1.0,IMPORTS:0.7,EXTENDS:1.1,IMPLEMENTS:1.0
SEMANTIC_GRAPH_QUERY_MAX_EDGES=400
SEMANTIC_GRAPH_QUERY_MAX_NODES=200
SEMANTIC_GRAPH_QUERY_MAX_MS=120
SEMANTIC_GRAPH_QUERY_FALLBACK_TO_STRUCTURAL=true
HEALTH_CHECK_STRICT=true
HEALTH_CHECK_TIMEOUT_SECONDS=5
HEALTH_CHECK_TTL_SECONDS=10
HEALTH_CHECK_OPENAI=false
HEALTH_CHECK_REDIS=false
MODEL_DISCOVERY_TIMEOUT_SECONDS=8
MODEL_DISCOVERY_CACHE_TTL_SECONDS=3600
MODEL_DISCOVERY_MAX_RESULTS=80
MODEL_DISCOVERY_GEMINI_SDK_ENABLED=true
